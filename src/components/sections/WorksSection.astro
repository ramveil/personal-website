---
import { getCollection } from "astro:content";
import WorkCard from "@/components/cards/WorkCard.astro";

interface Props {
  limit?: number;
}

const { limit } = Astro.props;

let allProjects = await getCollection("projects");

allProjects = allProjects.sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);

if (limit !== undefined) {
  allProjects = allProjects.slice(0, limit);
}
---

<section class="py-8 md:py-8">
  <div class="space-y-8 md:space-y-10">
    {allProjects
      .filter(project => project.data.isShow !== false)
      .map((project, index) => (
        <WorkCard
          name={project.data.title}
          description={project.data.description}
          image={project.data.image}
          url={`/projects/${project.id}`}
          tags={project.data.tags}
          video={project.data.video}
          isShow={project.data.isShow}
          layout="featured"
          index={index}
        />
      ))}
  </div>
</section>
