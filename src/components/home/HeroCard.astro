---
interface Props {
  imageUrl: string;
  title?: string;
  link?: string;
}

const { imageUrl } = Astro.props;
---

<div class="w-full flex justify-center md:justify-end">
  <img
    src={imageUrl}
    alt="Hero image"
    loading="eager"
    decoding="async"
    class="block w-full max-w-[700px] h-auto object-contain"
  />
</div>